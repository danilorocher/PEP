# ==========================================
# PEP+ ENVIRONMENT VARIABLES
# ==========================================

# 1. DATABASE (PostgreSQL)
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL="postgresql://pep_admin:pep_password@localhost:5432/pep_plus_db?schema=public"

# 2. CACHE & QUEUES (Redis)
REDIS_HOST="localhost"
REDIS_PORT=6379

# 3. AUTHENTICATION (JWT)
JWT_SECRET="chave_super_secreta_jwt_para_access_token_15m"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="chave_super_secreta_jwt_para_refresh_token_7d"
JWT_REFRESH_EXPIRES_IN="7d"

# 4. ENCRYPTION (AES-256-GCM)
# Chave mestra de 32 bytes (256 bits) para criptografia de dados sensíveis (CPF, CNS, Diagnósticos)
ENCRYPTION_KEY="chave_mestra_super_segura_de_32_caracteres"

# 5. ENVIRONMENT
NODE_ENV="development"
PORT=3000