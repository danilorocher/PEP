generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// ENUMS GLOBAIS
// ==========================================
enum PlanType {
  BASIC
  STANDARD
  ENTERPRISE
}

enum UserRole {
  ADMIN
  MEDICO
  ENFERMEIRO
  RECEPCIONISTA
  FATURAMENTO
  PACIENTE
}

enum Gender {
  MASCULINO
  FEMININO
  OUTRO
}

enum EntityStatus {
  ATIVO
  INATIVO
}

enum NurseCategory {
  ENFERMEIRO
  TECNICO
  AUXILIAR
}

enum WardType {
  UTI
  ENFERMARIA
  EMERGENCIA
  AMBULATORIO
  CIRURGICO
  PEDIATRIA
  MATERNIDADE
}

enum BedType {
  UTI
  CLINICO
  ISOLAMENTO
  PEDIATRICO
  CIRURGICO
}

enum BedStatus {
  LIVRE
  OCUPADO
  MANUTENCAO
  RESERVADO
}

enum BloodGroup {
  A_POSITIVO
  A_NEGATIVO
  B_POSITIVO
  B_NEGATIVO
  AB_POSITIVO
  AB_NEGATIVO
  O_POSITIVO
  O_NEGATIVO
}

enum PatientStatus {
  ATIVO
  INATIVO
  OBITO
}

enum InsuranceType {
  PLANO_SAUDE
  CONVENIO
  PARTICULAR
  SUS
}

enum PharmaForm {
  COMPRIMIDO
  CAPSULA
  INJETAVEL
  SOLUCAO
  XAROPE
  CREME
  SUPOSITORIO
  OUTRO
}

enum AdminRoute {
  ORAL
  INTRAVENOSA
  INTRAMUSCULAR
  SUBCUTANEA
  TOPICA
  INALATORIA
  OUTRO
}

enum ExamType {
  LABORATORIAL
  IMAGEM
  FUNCIONAL
  OUTRO
}

enum MedRecordStatus {
  ABERTO
  FECHADO
  ARQUIVADO
}

enum ProfType {
  MEDICO
  ENFERMEIRO
  FISIOTERAPEUTA
  OUTRO
}

enum PrescStatus {
  ATIVA
  SUSPENSA
  CONCLUIDA
  CANCELADA
}

enum ItemStatus {
  ATIVO
  SUSPENSO
  CONCLUIDO
}

enum MedAdminStatus {
  MINISTRADO
  ATRASADO
  NAO_MINISTRADO
  RECUSADO_PACIENTE
}

enum UrgencyType {
  ROTINA
  URGENTE
  EMERGENCIA
}

enum ExamReqStatus {
  SOLICITADO
  COLETADO
  EM_ANALISE
  CONCLUIDO
  CANCELADA
}

enum HospType {
  ELETIVA
  URGENCIA
  EMERGENCIA
}

enum AccomodationType {
  ENFERMARIA
  APARTAMENTO
  UTI
}

enum DischargeCondition {
  ALTA_MELHORADO
  ALTA_CURADO
  ALTA_PEDIDO
  OBITO
  TRANSFERENCIA
}

enum HospStatus {
  ATIVA
  ALTA
  TRANSFERIDO
  OBITO
}

enum ApptType {
  CONSULTA
  RETORNO
  EXAME
  PROCEDIMENTO
}

enum ApptStatus {
  AGENDADO
  CONFIRMADO
  EM_ATENDIMENTO
  REALIZADO
  CANCELADO
  FALTOU
}

enum BillingType {
  INTERNACAO
  CONSULTA
  SADT
}

enum BillingGuideStatus {
  RASCUNHO
  ENVIADA
  AUTORIZADA
  NEGADA
  PAGA
  GLOSADA
}

enum BillingItemStatus {
  AUTORIZADO
  GLOSADO
}

enum FluidEntryType {
  ORAL
  INTRAVENOSA
  SONDAS
  HEMODERIVADOS
  DIETA
  OUTROS
}

enum FluidOutputType {
  DIURESE
  DRENO
  VOMITO
  SANGRAMENTO
  EVACUACAO
  OUTROS
}

enum FluidBalanceStatus {
  EM_ANDAMENTO
  FECHADO
}

enum DispensationStatus {
  PENDENTE
  SEPARADA
  DISPENSADA
  CANCELADA
}

enum ControlledOperation {
  ENTRADA
  SAIDA
  PERDA
  DEVOLUCAO
}

enum InteractionSeverity {
  LEVE
  MODERADA
  GRAVE
  CONTRAINDICADA
}

enum KardexAction {
  PRESCRITO
  VALIDADO
  DISPENSADO
  ADMINISTRADO
  SUSPENSO
  DEVOLVIDO
}

enum SurgicalStatus {
  AGENDADO
  PRE_OPERATORIO
  EM_ANDAMENTO
  RECUPERACAO
  FINALIZADO
  CANCELADO
}

enum SurgicalPriority {
  ELETIVA
  URGENCIA
  EMERGENCIA
}

enum ResourceType {
  SALA
  EQUIPAMENTO
}

enum AccountStatus {
  OPEN
  CLOSED
  BILLED
  DENIED
  PAID
}

enum AccountItemType {
  PROCEDURE
  MEDICATION
  MATERIAL
  DAILY_RATE
  FEE
}

enum SourceModule {
  PRESCRIPTION
  SURGERY
  PHARMACY
  ATTENDANCE
  MANUAL
}

enum SUSBillingType {
  AIH
  BPA
}

enum SUSBillingStatus {
  GENERATED
  SENT
  ACCEPTED
  DENIED
}

enum DenialStatus {
  OPEN
  APPEALED
  RESOLVED
}

enum LabOrderStatus {
  REQUESTED
  COLLECTED
  PROCESSING
  COMPLETED
  CANCELLED
}

enum LabSampleStatus {
  COLLECTED
  SENT
  ANALYZED
  REJECTED
}

enum LabExamCategory {
  HEMATOLOGY
  BIOCHEMISTRY
  MICROBIOLOGY
  IMMUNOLOGY
  URINALYSIS
  OTHER
}

// ==========================================
// 1. TENANT E USUÁRIOS
// ==========================================
model Tenant {
  id                 String              @id @default(uuid())
  name               String
  subdomain          String              @unique
  cnpj               String?
  email              String?
  telefone           String?
  enderecoCompleto   Json?
  plano              PlanType            @default(BASIC)
  isActive           Boolean             @default(true)
  logoUrl            String?
  configuracoes      Json?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?
  users              User[]
  roles              Role[]
  auditLogs          AuditLog[]
  doctors            Doctor[]
  nurses             Nurse[]
  wards              Ward[]
  beds               Bed[]
  patients           Patient[]
  insurances         Insurance[]
  medications        Medication[]
  exams              Exam[]
  medicalRecords     MedicalRecord[]
  clinicalEvolutions ClinicalEvolution[]
  prescriptions      Prescription[]
  hospitalizations   Hospitalization[]
  appointments       Appointment[]
  occupations        Occupation[]
  specialties        Specialty[]

  examRequests            ExamRequest[]
  billingGuides           BillingGuide[]
  medicationAdministrations MedicationAdministration[]

  vitalSigns         VitalSign[]
  fluidBalances      FluidBalance[]
  fluidEntries       FluidEntry[]
  fluidOutputs       FluidOutput[]
  bradenAssessments  BradenAssessment[]
  morseAssessments   MorseAssessment[]
  glasgowAssessments GlasgowAssessment[]

  medicationStocks MedicationStock[]
  dispensations    MedicationDispensation[]
  controlledLogs   ControlledMedicationLog[]
  drugInteractions DrugInteraction[]

  kardexRecords MedicationKardex[]

  surgicalResources SurgicalResource[]
  surgicalSchedules SurgicalSchedule[]
  preOpChecklists   PreOpChecklist[]
  
  anesthesiaRecords AnesthesiaRecord[]
  surgicalReports   SurgicalReport[]
  opmeItems         OPMEItem[]
  surgeryOPMEs      SurgeryOPME[]
  postOpChecklists  PostOpChecklist[]

  hospitalAccounts     HospitalAccount[]
  hospitalAccountItems HospitalAccountItem[]
  susBillings          SUSBilling[]
  billingDenials       BillingDenial[]
  drgGroups            DRGGroup[]

  labExams             LabExam[]
  labOrders            LabOrder[]
  labSamples           LabSample[]
  labResults           LabResult[]
  labReports           LabReport[]

  @@index([deletedAt])
}

model Role {
  id              String    @id @default(uuid())
  tenantId        String
  nome            String
  permissoes      Json
  hashPermissoes  String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  users           User[]

  @@unique([nome, tenantId])
  @@index([tenantId, hashPermissoes]) 
  @@index([tenantId, deletedAt])
}

// 🔥 NOVO: Catálogo Dinâmico de Cargos (CBO)
model Occupation {
  id          String   @id @default(uuid())
  tenantId    String
  nome        String
  codigoCBO   String?
  tipoBase    String   // MEDICO, ENFERMEIRO, ADMINISTRATIVO
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  users       User[]
  doctors     Doctor[]
  nurses      Nurse[]

  @@index([tenantId, deletedAt])
}

model User {
  id                 String    @id @default(uuid())
  tenantId           String
  roleId             String
  nomeCompleto       String
  cpf                String 
  cpfHash            String?
  dataNascimento     DateTime?
  sexo               Gender?
  email              String
  telefone           String?
  enderecoCompleto   Json?
  password           String
  roleName           UserRole  @default(RECEPCIONISTA)
  isActive           Boolean   @default(true)
  dataAdmissao       DateTime?
  mustChangePassword Boolean   @default(false)
  ultimoAcesso       DateTime?

  // 🔥 Vínculo com o Cargo Dinâmico
  occupationId       String?
  occupation         Occupation? @relation(fields: [occupationId], references: [id])

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?
  tenant             Tenant    @relation(fields: [tenantId], references: [id])
  role               Role      @relation(fields: [roleId], references: [id])

  doctor            Doctor?
  nurse             Nurse?
  auditLogs         AuditLog[]
  recordsOpened     MedicalRecord[]            @relation("ResponsavelAbertura")
  evolutionsCreated ClinicalEvolution[]
  prescriptions     Prescription[]
  administrations   MedicationAdministration[]

  vitalSignsRegistered    VitalSign[]
  fluidBalancesRegistered FluidBalance[]
  fluidEntriesRegistered  FluidEntry[]
  fluidOutputsRegistered  FluidOutput[]
  bradenAssessments       BradenAssessment[]
  morseAssessments        MorseAssessment[]
  glasgowAssessments      GlasgowAssessment[]

  dispensationsApproved MedicationDispensation[]
  controlledLogs        ControlledMedicationLog[]
  kardexRecords         MedicationKardex[]

  preOpChecklistsFilled  PreOpChecklist[]
  postOpChecklistsFilled PostOpChecklist[]

  labOrdersRequested  LabOrder[]  @relation("DoctorLabOrders")
  labSamplesCollected LabSample[] @relation("NurseLabSamples")
  labResultsReleased  LabResult[] @relation("PathologistLabResults")
  labReportsSigned    LabReport[] @relation("PathologistLabReports")

  @@unique([email, tenantId])
  @@unique([cpfHash, tenantId])
  @@index([tenantId, deletedAt])
  @@index([tenantId, cpfHash, deletedAt])
  @@index([tenantId, email, deletedAt])
}

model AuditLog {
  id              String   @id @default(uuid())
  tenantId        String
  userId          String
  acao            String
  entidade        String
  entidadeId      String
  dadosAnteriores Json?
  dadosNovos      Json?
  ip              String?
  userAgent       String?
  createdAt       DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([tenantId, entidade, entidadeId])
  @@index([tenantId, userId])
}

// ==========================================
// 2. PROFISSIONAIS DE SAÚDE
// ==========================================
model Doctor {
  id                    String            @id @default(uuid())
  tenantId              String
  userId                String?           @unique
  nomeCompleto          String
  cpf                   String 
  cpfHash               String?
  crm                   String
  ufCrm                 String
  dataExpedicaoCrm      DateTime?
  cns                   String?
  cnsHash               String?
  telefoneProfissional  String?
  emailProfissional     String?
  registroSecundario    String?
  assinaturaDigitalPath String?
  status                EntityStatus      @default(ATIVO)

  // 🔥 Vínculo com o Cargo Dinâmico
  occupationId          String?
  occupation            Occupation?       @relation(fields: [occupationId], references: [id])

  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  deletedAt             DateTime?
  tenant                Tenant            @relation(fields: [tenantId], references: [id])
  user                  User?             @relation(fields: [userId], references: [id])
  specialties           DoctorSpecialty[]
  hospitalizationsResp  Hospitalization[] @relation("MedicoResponsavel")
  hospitalizationsDisch Hospitalization[] @relation("MedicoAlta")
  examRequests          ExamRequest[]
  appointments          Appointment[]

  surgeriesAsSurgeon      SurgicalSchedule[] @relation("CirurgiaoPrincipal")
  surgeriesAsAnesthetist  SurgicalSchedule[] @relation("AnestesistaResponsavel")
  anesthesiaRecordsFilled AnesthesiaRecord[] @relation("AnestesistaFicha")
  surgicalReportsFilled   SurgicalReport[]   @relation("CirurgiaoRelatorio")

  @@unique([crm, ufCrm, tenantId])
  @@unique([cpfHash, tenantId])
  @@index([tenantId, deletedAt])
  @@index([tenantId, crm, deletedAt])
}

// 🔥 Especialidades isoladas por Unidade
model Specialty {
  id         String   @id @default(uuid())
  tenantId   String
  nome       String   
  codigoCBOS String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant       Tenant            @relation(fields: [tenantId], references: [id])
  doctors      DoctorSpecialty[]
  appointments Appointment[]

  @@unique([nome, tenantId]) 
  @@index([tenantId])
}

model DoctorSpecialty {
  doctorId    String
  specialtyId String

  doctor    Doctor    @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  specialty Specialty @relation(fields: [specialtyId], references: [id], onDelete: Cascade)

  @@id([doctorId, specialtyId])
}

model Nurse {
  id                 String        @id @default(uuid())
  tenantId           String
  userId             String?       @unique
  nomeCompleto       String
  cpf                String 
  cpfHash            String?
  coren              String
  ufCoren            String
  dataExpedicaoCoren DateTime?
  categoria          NurseCategory
  cns                String?
  cnsHash            String?
  podePrescrever     Boolean       @default(false)
  status             EntityStatus  @default(ATIVO)

  // 🔥 Vínculo com o Cargo Dinâmico
  occupationId       String?
  occupation         Occupation?   @relation(fields: [occupationId], references: [id])

  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  deletedAt          DateTime?
  tenant             Tenant        @relation(fields: [tenantId], references: [id])
  user               User?         @relation(fields: [userId], references: [id])

  surgeriesAsNurse SurgicalSchedule[] @relation("EnfermeiroCirculante")

  @@unique([coren, ufCoren, tenantId])
  @@unique([cpfHash, tenantId])
  @@index([tenantId, deletedAt])
  @@index([tenantId, coren, deletedAt])
}

// ==========================================
// 3. ESTRUTURA HOSPITALAR E CATÁLOGOS
// ==========================================
model Ward {
  id               String            @id @default(uuid())
  tenantId         String
  nome             String
  tipo             WardType
  capacidade       Int
  andar            String?
  status           EntityStatus      @default(ATIVO)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?
  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  beds             Bed[]
  hospitalizations Hospitalization[]

  @@index([tenantId, deletedAt])
  @@index([tenantId, status, deletedAt])
}

model Bed {
  id               String            @id @default(uuid())
  tenantId         String
  wardId           String
  numero           String
  tipo             BedType
  status           BedStatus         @default(LIVRE)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?
  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  ward             Ward              @relation(fields: [wardId], references: [id])
  hospitalizations Hospitalization[]

  @@unique([numero, wardId, tenantId])
  @@index([tenantId, deletedAt])
  @@index([tenantId, wardId, deletedAt])
  @@index([tenantId, status, deletedAt])
}

model Insurance {
  id               String            @id @default(uuid())
  tenantId         String
  nome             String
  registroANS      String?
  tipo             InsuranceType
  telefone         String?
  email            String?
  status           EntityStatus      @default(ATIVO)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?
  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  patients         Patient[]
  hospitalizations Hospitalization[]
  appointments     Appointment[]
  billingGuides    BillingGuide[]

  @@index([tenantId, deletedAt])
}

model Cid10 {
  id                 String   @id @default(uuid())
  codigo             String   @unique
  descricao          String
  descricaoAbreviada String?
  capitulo           String?
  grupo              String?
  createdAt          DateTime @default(now())

  evolutions         ClinicalEvolution[]
  hospitalizationsAd Hospitalization[]   @relation("CidAdmissao")
  hospitalizationsDi Hospitalization[]   @relation("CidAlta")
  appointments       Appointment[]
  examRequests       ExamRequest[]
}

model Medication {
  id                     String             @id @default(uuid())
  tenantId               String
  nome                   String
  principioAtivo         String?
  concentracao           String?
  formaFarmaceutica      PharmaForm
  fabricante             String?
  codigoInterno          String?
  codigoEAN              String?
  controleEspecial       Boolean            @default(false)
  viaAdministracaoPadrao AdminRoute
  status                 EntityStatus       @default(ATIVO)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  deletedAt              DateTime?
  tenant                 Tenant             @relation(fields: [tenantId], references: [id])
  prescriptionItems      PrescriptionItem[]
  billingItems           BillingItem[]

  stocks         MedicationStock[]
  controlledLogs ControlledMedicationLog[]
  kardexRecords  MedicationKardex[]
  interactionsA  DrugInteraction[]         @relation("InteractionMedA")
  interactionsB  DrugInteraction[]         @relation("InteractionMedB")

  @@index([tenantId, deletedAt])
}

model Exam {
  id                   String        @id @default(uuid())
  tenantId             String
  nome                 String
  tipo                 ExamType
  tempoMedioResultado  Int?
  preparacaoNecessaria String?
  codigoInterno        String?
  codigoTUSS           String?
  status               EntityStatus  @default(ATIVO)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  deletedAt            DateTime?
  tenant               Tenant        @relation(fields: [tenantId], references: [id])
  requests             ExamRequest[]
  billingItems         BillingItem[]

  @@index([tenantId, deletedAt])
}

// ==========================================
// 4. PACIENTES E PRONTUÁRIO
// ==========================================
model Patient {
  id                      String        @id @default(uuid())
  tenantId                String
  convenioId              String?
  nomeCompleto            String
  cpf                     String 
  cpfHash                 String?
  cns                     String?
  cnsHash                 String?
  dataNascimento          DateTime
  sexo                    Gender
  nomeMae                 String?
  nomePai                 String?
  enderecoCompleto        Json?
  telefone                String?
  contatoEmergencia       Json?
  numeroCarteirinha       String?
  dataValidadeCarteirinha DateTime?
  alergias                String[]
  comorbidades            String[]
  historicoClinico        String?
  grupoSanguineo          BloodGroup?
  status                  PatientStatus @default(ATIVO)
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
  deletedAt               DateTime?
  tenant                  Tenant        @relation(fields: [tenantId], references: [id])
  insurance               Insurance?    @relation(fields: [convenioId], references: [id])

  medicalRecords   MedicalRecord[]
  hospitalizations Hospitalization[]
  appointments     Appointment[]
  examRequests     ExamRequest[]
  billingGuides    BillingGuide[]

  vitalSigns         VitalSign[]
  fluidBalances      FluidBalance[]
  bradenAssessments  BradenAssessment[]
  morseAssessments   MorseAssessment[]
  glasgowAssessments GlasgowAssessment[]

  controlledLogs ControlledMedicationLog[]
  kardexRecords  MedicationKardex[]

  surgicalSchedules SurgicalSchedule[]
  hospitalAccounts  HospitalAccount[]

  labOrders         LabOrder[]

  @@unique([cpfHash, tenantId])
  @@index([tenantId, deletedAt])
  @@index([tenantId, cpfHash, deletedAt])
  @@index([tenantId, nomeCompleto, deletedAt])
}

model MedicalRecord {
  id                    String          @id @default(uuid())
  tenantId              String
  patientId             String
  numero                String
  abertoEm              DateTime        @default(now())
  fechadoEm             DateTime?
  status                MedRecordStatus @default(ABERTO)
  responsavelAberturaId String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  deletedAt             DateTime?
  tenant                Tenant          @relation(fields: [tenantId], references: [id])
  patient               Patient         @relation(fields: [patientId], references: [id])
  responsavelAbertura   User?           @relation("ResponsavelAbertura", fields: [responsavelAberturaId], references: [id])

  evolutions       ClinicalEvolution[]
  prescriptions    Prescription[]
  examRequests     ExamRequest[]
  hospitalizations Hospitalization[]

  kardexRecords MedicationKardex[]

  surgicalSchedules SurgicalSchedule[]

  @@unique([numero, tenantId])
  @@index([tenantId, deletedAt])
  @@index([tenantId, patientId, deletedAt])
}

model ClinicalEvolution {
  id                   String           @id @default(uuid())
  tenantId             String
  medicalRecordId      String
  hospitalizationId    String?
  profissionalId       String
  cid10Id              String?
  tipoProfissional     ProfType
  descricao            String 
  dataHora             DateTime         @default(now())
  versao               Int              @default(1)
  assinadoDigitalmente Boolean          @default(false)
  assinaturaHash       String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  deletedAt            DateTime?
  tenant               Tenant           @relation(fields: [tenantId], references: [id])
  medicalRecord        MedicalRecord    @relation(fields: [medicalRecordId], references: [id])
  hospitalization      Hospitalization? @relation(fields: [hospitalizationId], references: [id])
  profissional         User             @relation(fields: [profissionalId], references: [id])
  cid10                Cid10?           @relation(fields: [cid10Id], references: [id])

  history ClinicalEvolutionHistory[]

  @@index([tenantId, deletedAt])
  @@index([tenantId, medicalRecordId, deletedAt])
  @@index([tenantId, profissionalId, deletedAt])
}

model ClinicalEvolutionHistory {
  id            String   @id @default(uuid())
  evolutionId   String
  versao        Int
  dadosSnapshot Json
  alteradoPor   String
  createdAt     DateTime @default(now())

  evolution ClinicalEvolution @relation(fields: [evolutionId], references: [id], onDelete: Cascade)
}

// ==========================================
// 5. PRESCRIÇÕES E EXAMES
// ==========================================
model Prescription {
  id                    String           @id @default(uuid())
  tenantId              String
  medicalRecordId       String
  hospitalizationId     String?
  prescritoPor          String
  tipoPrescrito         ProfType
  dataHora              DateTime         @default(now())
  status                PrescStatus      @default(ATIVA)
  observacoes           String?
  assinadaDigitalmente  Boolean          @default(false)
  assinaturaHash        String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  deletedAt             DateTime?
  tenant                Tenant           @relation(fields: [tenantId], references: [id])
  medicalRecord         MedicalRecord    @relation(fields: [medicalRecordId], references: [id])
  hospitalization       Hospitalization? @relation(fields: [hospitalizationId], references: [id])
  prescritor            User             @relation(fields: [prescritoPor], references: [id])

  items PrescriptionItem[]

  dispensations MedicationDispensation[]

  @@index([tenantId, deletedAt])
  @@index([tenantId, medicalRecordId, deletedAt])
}

model PrescriptionItem {
  id                  String                     @id @default(uuid())
  prescriptionId      String
  medicationId        String
  dosagem             String
  viaAdministracao    AdminRoute
  frequencia          String
  horariosProgramados String[]
  duracaoDias         Int?
  dataInicio          DateTime
  dataFim             DateTime?
  observacoes         String?
  status              ItemStatus                 @default(ATIVO)
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  deletedAt           DateTime?
  prescription        Prescription               @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  medication          Medication                 @relation(fields: [medicationId], references: [id])
  administrations     MedicationAdministration[]

  dispensationItems DispensationItem[]

  @@index([prescriptionId, deletedAt])
}

model MedicationAdministration {
  id                   String           @id @default(uuid())
  tenantId             String
  prescriptionItemId   String
  hospitalizationId    String?
  administradoPor      String?
  dataHoraProgamada    DateTime
  dataHoraAdministrada DateTime?
  status               MedAdminStatus   @default(NAO_MINISTRADO)
  observacoes          String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  deletedAt            DateTime?
  tenant               Tenant           @relation(fields: [tenantId], references: [id])
  prescriptionItem     PrescriptionItem @relation(fields: [prescriptionItemId], references: [id])
  hospitalization      Hospitalization? @relation(fields: [hospitalizationId], references: [id])
  administrador        User?            @relation(fields: [administradoPor], references: [id])

  @@index([tenantId, deletedAt])
  @@index([tenantId, hospitalizationId, deletedAt])
  @@index([status, dataHoraProgamada, deletedAt])
}

model ExamRequest {
  id                        String           @id @default(uuid())
  tenantId                  String
  medicalRecordId           String
  hospitalizationId         String?
  solicitadoPor             String
  patientId                 String
  examId                    String
  cid10Id                   String?
  dataHoraSolicitacao       DateTime         @default(now())
  urgencia                  UrgencyType      @default(ROTINA)
  status                    ExamReqStatus    @default(SOLICITADO)
  resultado                 String?
  dataHoraResultado         DateTime?
  observacoes               String?
  codigoAutorizacaoConvenio String?
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt
  deletedAt                 DateTime?
  tenant                    Tenant           @relation(fields: [tenantId], references: [id])
  medicalRecord             MedicalRecord    @relation(fields: [medicalRecordId], references: [id])
  hospitalization           Hospitalization? @relation(fields: [hospitalizationId], references: [id])
  doctor                    Doctor           @relation(fields: [solicitadoPor], references: [id])
  patient                   Patient          @relation(fields: [patientId], references: [id])
  exam                      Exam             @relation(fields: [examId], references: [id])
  cid10                     Cid10?           @relation(fields: [cid10Id], references: [id])

  @@index([tenantId, deletedAt])
  @@index([tenantId, patientId, deletedAt])
  @@index([tenantId, status, deletedAt])
}

// ==========================================
// 6. INTERNAÇÃO E AGENDAMENTO
// ==========================================
model Hospitalization {
  id                   String              @id @default(uuid())
  tenantId             String
  medicalRecordId      String
  patientId            String
  bedId                String
  wardId               String
  medicoResponsavelId  String
  cid10AdmissaoId      String
  cid10AltaId          String?
  convenioId           String?
  medicoAltaId         String?
  dataEntrada          DateTime            @default(now())
  dataPrevistaAlta     DateTime?
  dataAlta             DateTime?
  motivoInternacao     String
  tipoInternacao       HospType
  tipoAcomodacao       AccomodationType
  numeroGuiaInternacao String?
  sumarioAlta          String?
  condicaoPacienteAlta DischargeCondition?
  status               HospStatus          @default(ATIVA)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  deletedAt            DateTime?
  tenant               Tenant              @relation(fields: [tenantId], references: [id])
  medicalRecord        MedicalRecord       @relation(fields: [medicalRecordId], references: [id])
  patient              Patient             @relation(fields: [patientId], references: [id])
  bed                  Bed                 @relation(fields: [bedId], references: [id])
  ward                 Ward                @relation(fields: [wardId], references: [id])
  medicoResponsavel    Doctor              @relation("MedicoResponsavel", fields: [medicoResponsavelId], references: [id])
  medicoAlta           Doctor?             @relation("MedicoAlta", fields: [medicoAltaId], references: [id])
  cidAdmissao          Cid10               @relation("CidAdmissao", fields: [cid10AdmissaoId], references: [id])
  cidAlta              Cid10?              @relation("CidAlta", fields: [cid10AltaId], references: [id])
  insurance            Insurance?          @relation(fields: [convenioId], references: [id])

  evolutions      ClinicalEvolution[]
  prescriptions   Prescription[]
  administrations MedicationAdministration[]
  examRequests    ExamRequest[]
  billingGuides   BillingGuide[]

  vitalSigns         VitalSign[]
  fluidBalances      FluidBalance[]
  bradenAssessments  BradenAssessment[]
  morseAssessments   MorseAssessment[]
  glasgowAssessments GlasgowAssessment[]

  hospitalAccounts HospitalAccount[]

  @@index([tenantId, deletedAt])
  @@index([tenantId, patientId, deletedAt])
  @@index([tenantId, status, deletedAt])
}

model Appointment {
  id                 String     @id @default(uuid())
  tenantId           String
  patientId          String
  doctorId           String
  specialtyId        String
  convenioId         String?
  cid10Id            String?
  dataHora           DateTime
  duracao            Int 
  tipo               ApptType
  status             ApptStatus @default(AGENDADO)
  motivoCancelamento String?
  numeroGuiaConsulta String?
  observacoes        String?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  deletedAt          DateTime?
  tenant             Tenant     @relation(fields: [tenantId], references: [id])
  patient            Patient    @relation(fields: [patientId], references: [id])
  doctor             Doctor     @relation(fields: [doctorId], references: [id])
  specialty          Specialty  @relation(fields: [specialtyId], references: [id])
  insurance          Insurance? @relation(fields: [convenioId], references: [id])
  cid10              Cid10?     @relation(fields: [cid10Id], references: [id])

  billingGuides    BillingGuide[]
  hospitalAccounts HospitalAccount[]

  @@index([tenantId, deletedAt])
  @@index([tenantId, doctorId, dataHora, deletedAt])
  @@index([tenantId, patientId, deletedAt])
  @@index([tenantId, status, deletedAt])
}

// ==========================================
// 7. FATURAMENTO (TISS BÁSICO)
// ==========================================
model BillingGuide {
  id                String             @id @default(uuid())
  tenantId          String
  patientId         String
  convenioId        String
  hospitalizationId String?
  appointmentId     String?
  tipo              BillingType
  numeroGuia        String?
  dataEmissao       DateTime           @default(now())
  dataAutorizacao   DateTime?
  codigoAutorizacao String?
  valorTotal        Float              @default(0.0)
  status            BillingGuideStatus @default(RASCUNHO)
  observacoes       String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?
  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  patient           Patient            @relation(fields: [patientId], references: [id])
  insurance         Insurance          @relation(fields: [convenioId], references: [id])
  hospitalization   Hospitalization?   @relation(fields: [hospitalizationId], references: [id])
  appointment       Appointment?       @relation(fields: [appointmentId], references: [id])

  items BillingItem[]

  @@index([tenantId, deletedAt])
  @@index([tenantId, status, deletedAt])
  @@index([tenantId, convenioId, deletedAt])
}

model BillingItem {
  id                    String            @id @default(uuid())
  billingGuideId        String
  examId                String?
  medicationId          String?
  procedimentoDescricao String
  codigoTUSS            String?
  quantidade            Int               @default(1)
  valorUnitario         Float
  valorTotal            Float
  status                BillingItemStatus @default(AUTORIZADO)
  motivoGlosa           String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  deletedAt             DateTime?
  billingGuide          BillingGuide      @relation(fields: [billingGuideId], references: [id], onDelete: Cascade)
  exam                  Exam?             @relation(fields: [examId], references: [id])
  medication            Medication?       @relation(fields: [medicationId], references: [id])

  @@index([billingGuideId, deletedAt])
}

// ==========================================
// 8. ASSISTÊNCIA: SINAIS VITAIS
// ==========================================
model VitalSign {
  id                String  @id @default(uuid())
  tenantId          String
  patientId         String
  hospitalizationId String?
  registeredById    String

  dataHora DateTime @default(now())

  systolicPressure  Int 
  diastolicPressure Int 
  temperature       Float 
  heartRate         Int 
  respiratoryRate   Int 
  spo2              Int 
  painScale         Int 

  observacoes       String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  deletedAt         DateTime?
  tenant            Tenant           @relation(fields: [tenantId], references: [id])
  patient           Patient          @relation(fields: [patientId], references: [id])
  hospitalization   Hospitalization? @relation(fields: [hospitalizationId], references: [id])
  registeredBy      User             @relation(fields: [registeredById], references: [id])

  @@index([tenantId, deletedAt])
  @@index([tenantId, patientId, dataHora])
  @@index([tenantId, hospitalizationId])
}

// ==========================================
// 9. ASSISTÊNCIA: BALANÇO HÍDRICO
// ==========================================
model FluidBalance {
  id                String  @id @default(uuid())
  tenantId          String
  patientId         String
  hospitalizationId String?
  registeredById    String

  dataHoraReferencia DateTime 

  totalInput  Float @default(0.0)
  totalOutput Float @default(0.0)
  balance     Float @default(0.0)

  status          FluidBalanceStatus @default(EM_ANDAMENTO)
  observacoes     String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  deletedAt       DateTime?
  tenant          Tenant             @relation(fields: [tenantId], references: [id])
  patient         Patient            @relation(fields: [patientId], references: [id])
  hospitalization Hospitalization?   @relation(fields: [hospitalizationId], references: [id])
  registeredBy    User               @relation(fields: [registeredById], references: [id])

  entries FluidEntry[]
  outputs FluidOutput[]

  @@index([tenantId, deletedAt])
  @@index([tenantId, patientId, dataHoraReferencia])
}

model FluidEntry {
  id             String @id @default(uuid())
  tenantId       String
  fluidBalanceId String
  registeredById String

  dataHora DateTime       @default(now())
  tipo     FluidEntryType

  volumeMl     Float
  descricao    String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?
  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  fluidBalance FluidBalance @relation(fields: [fluidBalanceId], references: [id], onDelete: Cascade)
  registeredBy User         @relation(fields: [registeredById], references: [id])

  @@index([tenantId, fluidBalanceId])
}

model FluidOutput {
  id             String @id @default(uuid())
  tenantId       String
  fluidBalanceId String
  registeredById String

  dataHora DateTime        @default(now())
  tipo     FluidOutputType

  volumeMl     Float
  descricao    String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?
  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  fluidBalance FluidBalance @relation(fields: [fluidBalanceId], references: [id], onDelete: Cascade)
  registeredBy User         @relation(fields: [registeredById], references: [id])

  @@index([tenantId, fluidBalanceId])
}

// ==========================================
// 10. ASSISTÊNCIA: ESCALAS DE RISCO
// ==========================================
model BradenAssessment {
  id                String  @id @default(uuid())
  tenantId          String
  patientId         String
  hospitalizationId String?
  registeredById    String

  dataHora DateTime @default(now())

  sensoryPerception Int
  moisture          Int
  activity          Int
  mobility          Int
  nutrition         Int
  frictionShear     Int 

  totalScore    Int
  classificacao String

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  patient         Patient          @relation(fields: [patientId], references: [id])
  hospitalization Hospitalization? @relation(fields: [hospitalizationId], references: [id])
  registeredBy    User             @relation(fields: [registeredById], references: [id])

  @@index([tenantId, patientId, dataHora])
}

model MorseAssessment {
  id                String  @id @default(uuid())
  tenantId          String
  patientId         String
  hospitalizationId String?
  registeredById    String

  dataHora DateTime @default(now())

  historyOfFalling   Int
  secondaryDiagnosis Int
  ambulatoryAid      Int
  ivTherapy          Int
  gait               Int
  mentalStatus       Int

  totalScore    Int
  classificacao String

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  patient         Patient          @relation(fields: [patientId], references: [id])
  hospitalization Hospitalization? @relation(fields: [hospitalizationId], references: [id])
  registeredBy    User             @relation(fields: [registeredById], references: [id])

  @@index([tenantId, patientId, dataHora])
}

model GlasgowAssessment {
  id                String  @id @default(uuid())
  tenantId          String
  patientId         String
  hospitalizationId String?
  registeredById    String

  dataHora DateTime @default(now())

  eyeOpening      Int 
  verbalResponse  Int 
  motorResponse   Int 
  pupilReactivity Int?
  totalScore      Int
  classificacao   String

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  patient         Patient          @relation(fields: [patientId], references: [id])
  hospitalization Hospitalization? @relation(fields: [hospitalizationId], references: [id])
  registeredBy    User             @relation(fields: [registeredById], references: [id])

  @@index([tenantId, patientId, dataHora])
}

// ==========================================
// 11. FARMÁCIA: ESTOQUE E LOTES
// ==========================================
model MedicationStock {
  id             String   @id @default(uuid())
  tenantId       String
  medicationId   String
  lote           String
  dataFabricacao DateTime?
  validade       DateTime
  quantidade     Float
  localizacao    String 

  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  deletedAt  DateTime?
  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  medication Medication @relation(fields: [medicationId], references: [id])

  dispensationItems DispensationItem[]
  controlledLogs    ControlledMedicationLog[]

  @@unique([medicationId, lote, localizacao, tenantId])
  @@index([tenantId, medicationId])
  @@index([tenantId, validade])
}

// ==========================================
// 12. FARMÁCIA: DISPENSAÇÃO
// ==========================================
model MedicationDispensation {
  id               String             @id @default(uuid())
  tenantId         String
  prescriptionId   String
  farmaceuticoId   String?
  status           DispensationStatus @default(PENDENTE)
  dataHoraDispensa DateTime?
  observacoes      String?

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?
  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  prescription Prescription @relation(fields: [prescriptionId], references: [id])
  farmaceutico User?        @relation(fields: [farmaceuticoId], references: [id])

  items DispensationItem[]

  @@index([tenantId, status])
  @@index([tenantId, prescriptionId])
}

model DispensationItem {
  id                   String @id @default(uuid())
  dispensationId       String
  prescriptionItemId   String
  stockId              String 
  quantidadeDispensada Float

  dispensation     MedicationDispensation @relation(fields: [dispensationId], references: [id], onDelete: Cascade)
  prescriptionItem PrescriptionItem       @relation(fields: [prescriptionItemId], references: [id])
  stock            MedicationStock        @relation(fields: [stockId], references: [id])

  @@index([dispensationId])
  @@index([prescriptionItemId])
}

// ==========================================
// 13. FARMÁCIA: PSICOTRÓPICOS E CONTROLADOS
// ==========================================
model ControlledMedicationLog {
  id            String  @id @default(uuid())
  tenantId      String
  medicationId  String
  stockId       String?
  pacienteId    String?
  responsavelId String

  tipoOperacao  ControlledOperation
  quantidade    Float
  justificativa String
  dataHora      DateTime            @default(now())

  createdAt DateTime @default(now())

  tenant      Tenant           @relation(fields: [tenantId], references: [id])
  medication  Medication       @relation(fields: [medicationId], references: [id])
  stock       MedicationStock? @relation(fields: [stockId], references: [id])
  paciente    Patient?         @relation(fields: [pacienteId], references: [id])
  responsavel User             @relation(fields: [responsavelId], references: [id])

  @@index([tenantId, medicationId])
  @@index([tenantId, dataHora])
}

// ==========================================
// 14. FARMÁCIA: INTERAÇÕES MEDICAMENTOSAS
// ==========================================
model DrugInteraction {
  id             String              @id @default(uuid())
  tenantId       String
  medicationAId  String
  medicationBId  String
  grauSeveridade InteractionSeverity
  descricao      String
  manejoClinico  String

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?
  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  medicationA Medication @relation("InteractionMedA", fields: [medicationAId], references: [id])
  medicationB Medication @relation("InteractionMedB", fields: [medicationBId], references: [id])

  @@unique([medicationAId, medicationBId, tenantId])
  @@index([tenantId])
}

// ==========================================
// 15. FARMÁCIA: KARDEX (Histórico)
// ==========================================
model MedicationKardex {
  id              String @id @default(uuid())
  tenantId        String
  patientId       String
  medicalRecordId String
  medicationId    String
  responsavelId   String

  acao     KardexAction
  detalhes String
  dataHora DateTime     @default(now())

  createdAt DateTime @default(now())

  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  patient       Patient       @relation(fields: [patientId], references: [id])
  medicalRecord MedicalRecord @relation(fields: [medicalRecordId], references: [id])
  medication    Medication    @relation(fields: [medicationId], references: [id])
  responsavel   User          @relation(fields: [responsavelId], references: [id])

  @@index([tenantId, patientId, dataHora])
  @@index([tenantId, medicalRecordId])
}

// ==========================================
// 16. CENTRO CIRÚRGICO: RECURSOS E SALAS
// ==========================================
model SurgicalResource {
  id              String       @id @default(uuid())
  tenantId        String
  nome            String
  tipo            ResourceType
  disponibilidade Boolean      @default(true)
  status          EntityStatus @default(ATIVO)

  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  deletedAt DateTime?
  tenant    Tenant             @relation(fields: [tenantId], references: [id])
  schedules SurgicalSchedule[]

  @@index([tenantId, tipo, disponibilidade])
  @@index([tenantId, deletedAt])
}

// ==========================================
// 17. CENTRO CIRÚRGICO: AGENDAMENTO
// ==========================================
model SurgicalSchedule {
  id              String   @id @default(uuid())
  tenantId        String
  patientId       String
  medicalRecordId String?
  procedimento    String
  dataCirurgia    DateTime
  salaId          String
  cirurgiaoId     String
  anestesistaId   String
  enfermeiroId    String

  status        SurgicalStatus   @default(AGENDADO)
  prioridade    SurgicalPriority @default(ELETIVA)
  observacoes   String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  deletedAt     DateTime?
  tenant        Tenant           @relation(fields: [tenantId], references: [id])
  patient       Patient          @relation(fields: [patientId], references: [id])
  medicalRecord MedicalRecord?   @relation(fields: [medicalRecordId], references: [id])
  sala          SurgicalResource @relation(fields: [salaId], references: [id])
  cirurgiao     Doctor           @relation("CirurgiaoPrincipal", fields: [cirurgiaoId], references: [id])
  anestesista   Doctor           @relation("AnestesistaResponsavel", fields: [anestesistaId], references: [id])
  enfermeiro    Nurse            @relation("EnfermeiroCirculante", fields: [enfermeiroId], references: [id])

  preOpChecklist  PreOpChecklist?
  postOpChecklist PostOpChecklist?
  anesthesia      AnesthesiaRecord?
  report          SurgicalReport?
  opmesUsed       SurgeryOPME[]

  @@index([tenantId, dataCirurgia, status])
  @@index([tenantId, salaId, dataCirurgia])
}

// ==========================================
// 18. CENTRO CIRÚRGICO: PRÉ-OPERATÓRIO (OMS)
// ==========================================
model PreOpChecklist {
  id                      String @id @default(uuid())
  tenantId                String
  cirurgiaId              String @unique
  profissionalResponsavel String

  pacienteConfirmado     Boolean  @default(false)
  lateralidadeConfirmada Boolean  @default(false)
  jejumConfirmado        Boolean  @default(false)
  consentimentoAssinado  Boolean  @default(false)
  alergiasVerificadas    Boolean  @default(false)
  status                 String   @default("PENDENTE")
  dataRegistro           DateTime @default(now())

  tenant   Tenant           @relation(fields: [tenantId], references: [id])
  cirurgia SurgicalSchedule @relation(fields: [cirurgiaId], references: [id], onDelete: Cascade)
  responsavel User          @relation(fields: [profissionalResponsavel], references: [id])

  @@index([tenantId, cirurgiaId])
}

// ==========================================
// 19. CENTRO CIRÚRGICO: REGISTRO ANESTÉSICO
// ==========================================
model AnesthesiaRecord {
  id            String @id @default(uuid())
  tenantId      String
  cirurgiaId    String @unique
  anestesistaId String

  tipoAnestesia    String
  drogasUtilizadas Json
  sinaisVitais     Json
  inicio           DateTime
  fim              DateTime?
  createdAt        DateTime @default(now())

  tenant   Tenant           @relation(fields: [tenantId], references: [id])
  cirurgia SurgicalSchedule @relation(fields: [cirurgiaId], references: [id], onDelete: Cascade)
  anestesista Doctor        @relation("AnestesistaFicha", fields: [anestesistaId], references: [id])

  @@index([tenantId, cirurgiaId])
}

// ==========================================
// 20. CENTRO CIRÚRGICO: RELATÓRIO CIRÚRGICO
// ==========================================
model SurgicalReport {
  id          String @id @default(uuid())
  tenantId    String
  cirurgiaId  String @unique
  cirurgiaoId String

  descricaoProcedimento String
  intercorrencias       String?
  materiaisUtilizados   String?
  dataRegistro          DateTime @default(now())

  createdAt DateTime @default(now())

  tenant    Tenant           @relation(fields: [tenantId], references: [id])
  cirurgia  SurgicalSchedule @relation(fields: [cirurgiaId], references: [id], onDelete: Cascade)
  cirurgiao Doctor           @relation("CirurgiaoRelatorio", fields: [cirurgiaoId], references: [id])

  @@index([tenantId, cirurgiaId])
}

// ==========================================
// 21. CENTRO CIRÚRGICO: OPME (ANVISA)
// ==========================================
model OPMEItem {
  id                   String        @id @default(uuid())
  tenantId             String
  nome                 String
  fabricante           String
  lote                 String
  numeroRegistroAnvisa String
  validade             DateTime
  status               EntityStatus @default(ATIVO)

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?
  tenant         Tenant        @relation(fields: [tenantId], references: [id])
  surgeriesUsage SurgeryOPME[]

  @@unique([tenantId, numeroRegistroAnvisa, lote])
  @@index([tenantId, status])
}

model SurgeryOPME {
  id                        String   @id @default(uuid())
  tenantId                  String
  cirurgiaId                String
  opmeId                    String
  quantidade                Float
  rastreabilidadeConfirmada Boolean  @default(false)
  dataRegistro              DateTime @default(now())

  tenant   Tenant           @relation(fields: [tenantId], references: [id])
  cirurgia SurgicalSchedule @relation(fields: [cirurgiaId], references: [id], onDelete: Cascade)
  opme     OPMEItem         @relation(fields: [opmeId], references: [id])

  @@index([tenantId, cirurgiaId])
  @@index([tenantId, opmeId])
}

// ==========================================
// 22. CENTRO CIRÚRGICO: PÓS-OP (SRPA)
// ==========================================
model PostOpChecklist {
  id                      String @id @default(uuid())
  tenantId                String
  cirurgiaId              String @unique
  profissionalResponsavel String

  nivelConsciencia String
  dor              Int
  sinaisVitais     Json
  liberadoAlta     Boolean  @default(false)
  dataRegistro     DateTime @default(now())

  tenant      Tenant           @relation(fields: [tenantId], references: [id])
  cirurgia    SurgicalSchedule @relation(fields: [cirurgiaId], references: [id], onDelete: Cascade)
  responsavel User             @relation(fields: [profissionalResponsavel], references: [id])

  @@index([tenantId, cirurgiaId])
}

// ==========================================
// 23. CONTA HOSPITALAR (PACIENTE / INTERNAÇÃO)
// ==========================================
model HospitalAccount {
  id                String        @id @default(uuid())
  tenantId          String
  patientId         String
  hospitalizationId String?
  appointmentId     String?
  drgGroupId        String?
  status            AccountStatus @default(OPEN)
  totalAmount       Float         @default(0.0)

  openedAt    DateTime  @default(now())
  closedAt    DateTime?
  billingDate DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  patient         Patient          @relation(fields: [patientId], references: [id])
  hospitalization Hospitalization? @relation(fields: [hospitalizationId], references: [id])
  appointment     Appointment?     @relation(fields: [appointmentId], references: [id])
  drgGroup        DRGGroup?        @relation(fields: [drgGroupId], references: [id])

  items       HospitalAccountItem[]
  susBillings SUSBilling[]
  denials     BillingDenial[]

  @@index([tenantId, status])
  @@index([tenantId, patientId])
}

model HospitalAccountItem {
  id        String @id @default(uuid())
  tenantId  String
  accountId String

  tipo        AccountItemType
  description String
  quantity    Float           @default(1.0)
  unitPrice   Float
  totalPrice  Float

  referenceId  String?
  sourceModule SourceModule

  timestamp DateTime  @default(now())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  tenant  Tenant          @relation(fields: [tenantId], references: [id])
  account HospitalAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([tenantId, accountId])
}

// ==========================================
// 24. FATURAMENTO SUS (AIH / BPA)
// ==========================================
model SUSBilling {
  id        String @id @default(uuid())
  tenantId  String
  accountId String

  type           SUSBillingType
  status         SUSBillingStatus @default(GENERATED)
  protocolNumber String?
  submissionDate DateTime?
  returnDate     DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  tenant  Tenant          @relation(fields: [tenantId], references: [id])
  account HospitalAccount @relation(fields: [accountId], references: [id])

  @@index([tenantId, type, status])
}

// ==========================================
// 25. GLOSAS HOSPITALARES
// ==========================================
model BillingDenial {
  id        String @id @default(uuid())
  tenantId  String
  accountId String

  reason       String
  amountDenied Float
  status       DenialStatus @default(OPEN)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  tenant  Tenant          @relation(fields: [tenantId], references: [id])
  account HospitalAccount @relation(fields: [accountId], references: [id])

  @@index([tenantId, status])
}

// ==========================================
// 26. DRG (Diagnosis Related Groups)
// ==========================================
model DRGGroup {
  id       String @id @default(uuid())
  tenantId String

  code        String
  description String
  averageCost Float

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  tenant   Tenant            @relation(fields: [tenantId], references: [id])
  accounts HospitalAccount[]

  @@unique([tenantId, code])
}

// ==========================================
// 🔬 MÓDULO LABORATÓRIO (LIS)
// ==========================================

model LabExam {
  id                   String          @id @default(uuid())
  tenantId             String
  name                 String
  code                 String          
  category             LabExamCategory
  unit                 String?
  referenceRangeMale   Json?           
  referenceRangeFemale Json?
  criticalMin          Float?
  criticalMax          Float?
  status               EntityStatus    @default(ATIVO)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  deletedAt            DateTime?
  tenant               Tenant          @relation(fields: [tenantId], references: [id])
  results              LabResult[]

  @@unique([tenantId, code])
  @@index([tenantId, deletedAt])
}

model LabOrder {
  id                String         @id @default(uuid())
  tenantId          String
  patientId         String
  medicalRecordId   String?
  appointmentId     String?
  hospitalizationId String?
  status            LabOrderStatus @default(REQUESTED)
  requestedBy       String         
  requestedAt       DateTime       @default(now())
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  deletedAt         DateTime?
  tenant         Tenant         @relation(fields: [tenantId], references: [id])
  patient           Patient        @relation(fields: [patientId], references: [id])
  requester         User           @relation("DoctorLabOrders", fields: [requestedBy], references: [id])
  
  samples           LabSample[]
  results           LabResult[]
  report            LabReport?
  @@index([tenantId, status])
  @@index([tenantId, patientId])
}

model LabSample {
  id           String          @id @default(uuid())
  tenantId     String
  labOrderId   String
  sampleType   String          
  barcode      String          @unique
  collectedAt  DateTime?
  collectedBy  String?         
  status       LabSampleStatus @default(COLLECTED)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  deletedAt    DateTime?
  tenant       Tenant          @relation(fields: [tenantId], references: [id])
  order        LabOrder        @relation(fields: [labOrderId], references: [id])
  collector    User?           @relation("NurseLabSamples", fields: [collectedBy], references: [id])

  @@index([tenantId, barcode])
}

model LabResult {
  id           String    @id @default(uuid())
  tenantId     String
  labOrderId   String
  examId       String
  value        String    
  numericValue Float?
  unit         String?
  referenceMin Float?
  referenceMax Float?
  isCritical   Boolean   @default(false)
  releasedAt   DateTime?
  releasedBy   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  order        LabOrder  @relation(fields: [labOrderId], references: [id])
  exam         LabExam   @relation(fields: [examId], references: [id])
  pathologist  User?     @relation("PathologistLabResults", fields: [releasedBy], references: [id])

  @@index([tenantId, labOrderId])
}

model LabReport {
  id               String    @id @default(uuid())
  tenantId         String
  labOrderId       String    @unique
  reportText       String    @db.Text
  signedBy         String?
  signedAt         DateTime?
  digitalSignature String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant           Tenant    @relation(fields: [tenantId], references: [id])
  order            LabOrder  @relation(fields: [labOrderId], references: [id])
  pathologist      User?     @relation("PathologistLabReports", fields: [signedBy], references: [id])

  @@index([tenantId, signedAt])
}